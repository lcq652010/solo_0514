{"remainingRequest":"C:\\Users\\86138\\Desktop\\solo_0516\\092\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!C:\\Users\\86138\\Desktop\\solo_0516\\092\\src\\views\\OrderForm.vue?vue&type=script&lang=js","dependencies":[{"path":"C:\\Users\\86138\\Desktop\\solo_0516\\092\\src\\views\\OrderForm.vue","mtime":1778911581384},{"path":"C:\\Users\\86138\\Desktop\\solo_0516\\092\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1778910668640},{"path":"C:\\Users\\86138\\Desktop\\solo_0516\\092\\node_modules\\vue-loader\\lib\\index.js","mtime":1778910681190}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["OrderForm.vue"],"names":[],"mappings":";AA2GA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA","file":"OrderForm.vue","sourceRoot":"src/views","sourcesContent":["<template>\r\n  <div class=\"order-form-container\">\r\n    <el-card class=\"order-card\" shadow=\"hover\">\r\n      <div slot=\"header\" class=\"card-header\">\r\n        <span>客户下单</span>\r\n      </div>\r\n      <el-form :model=\"orderForm\" :rules=\"rules\" ref=\"orderForm\" label-width=\"120px\">\r\n        <el-row :gutter=\"20\">\r\n          <el-col :span=\"12\">\r\n            <el-form-item label=\"木料种类\" prop=\"woodType\">\r\n              <el-select v-model=\"orderForm.woodType\" placeholder=\"请选择木料\" style=\"width: 100%\">\r\n                <el-option\r\n                  v-for=\"wood in woodTypes\"\r\n                  :key=\"wood.value\"\r\n                  :label=\"wood.label\"\r\n                  :value=\"wood.value\">\r\n                  <span style=\"float: left\">{{ wood.label }}</span>\r\n                  <span style=\"float: right; color: #8492a6; font-size: 13px\">¥{{ wood.price }}</span>\r\n                </el-option>\r\n              </el-select>\r\n            </el-form-item>\r\n          </el-col>\r\n          <el-col :span=\"12\">\r\n            <el-form-item label=\"瑞兽款式\" prop=\"beastStyle\">\r\n              <el-select v-model=\"orderForm.beastStyle\" placeholder=\"请选择款式\" style=\"width: 100%\">\r\n                <el-option\r\n                  v-for=\"style in beastStyles\"\r\n                  :key=\"style.value\"\r\n                  :label=\"style.label\"\r\n                  :value=\"style.value\">\r\n                  <span style=\"float: left\">{{ style.label }}</span>\r\n                  <span style=\"float: right; color: #8492a6; font-size: 13px\">{{ style.desc }}</span>\r\n                </el-option>\r\n              </el-select>\r\n            </el-form-item>\r\n          </el-col>\r\n        </el-row>\r\n\r\n        <el-divider content-position=\"left\">尺寸规格（单位：厘米）</el-divider>\r\n\r\n        <el-row :gutter=\"20\">\r\n              <el-col :span=\"8\">\r\n                <el-form-item label=\"长度\" prop=\"length\">\r\n                  <el-input-number v-model=\"orderForm.length\" :min=\"sizeRules.length.min\" :max=\"sizeRules.length.max\" :step=\"sizeRules.length.step\" style=\"width: 100%\"></el-input-number>\r\n                </el-form-item>\r\n              </el-col>\r\n              <el-col :span=\"8\">\r\n                <el-form-item label=\"宽度\" prop=\"width\">\r\n                  <el-input-number v-model=\"orderForm.width\" :min=\"sizeRules.width.min\" :max=\"sizeRules.width.max\" :step=\"sizeRules.width.step\" style=\"width: 100%\"></el-input-number>\r\n                </el-form-item>\r\n              </el-col>\r\n              <el-col :span=\"8\">\r\n                <el-form-item label=\"高度\" prop=\"height\">\r\n                  <el-input-number v-model=\"orderForm.height\" :min=\"sizeRules.height.min\" :max=\"sizeRules.height.max\" :step=\"sizeRules.height.step\" style=\"width: 100%\"></el-input-number>\r\n                </el-form-item>\r\n              </el-col>\r\n            </el-row>\r\n\r\n        <el-divider content-position=\"left\">附加选项</el-divider>\r\n\r\n        <el-row :gutter=\"20\">\r\n          <el-col :span=\"24\">\r\n            <el-form-item label=\"是否鎏金\">\r\n              <el-switch\r\n                v-model=\"orderForm.isGilded\"\r\n                active-text=\"是\"\r\n                inactive-text=\"否\">\r\n              </el-switch>\r\n              <span class=\"gilded-tip\">鎏金工艺额外收取 ¥200 工本费</span>\r\n            </el-form-item>\r\n          </el-col>\r\n        </el-row>\r\n\r\n        <el-row :gutter=\"20\">\r\n          <el-col :span=\"24\">\r\n            <el-form-item label=\"客户备注\" prop=\"remark\">\r\n              <el-input\r\n                type=\"textarea\"\r\n                :rows=\"4\"\r\n                placeholder=\"请输入您的特殊要求或备注信息...\"\r\n                v-model=\"orderForm.remark\">\r\n              </el-input>\r\n            </el-form-item>\r\n          </el-col>\r\n        </el-row>\r\n\r\n        <el-divider></el-divider>\r\n\r\n        <el-row :gutter=\"20\">\r\n          <el-col :span=\"12\">\r\n            <div class=\"price-summary\">\r\n              <p class=\"price-label\">预估总价：</p>\r\n              <p class=\"price-value\">¥{{ totalPrice }}</p>\r\n            </div>\r\n          </el-col>\r\n          <el-col :span=\"12\">\r\n            <el-form-item>\r\n              <el-button type=\"primary\" size=\"large\" @click=\"submitOrder\" style=\"width: 100%\">提交订单</el-button>\r\n            </el-form-item>\r\n          </el-col>\r\n        </el-row>\r\n      </el-form>\r\n    </el-card>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport orderStore from '../store/orderStore'\r\n\r\nexport default {\r\n  name: 'OrderForm',\r\n  data() {\r\n    const sizeRules = orderStore.sizeRules\r\n    return {\r\n      woodTypes: orderStore.woodTypes,\r\n      beastStyles: orderStore.beastStyles,\r\n      sizeRules: sizeRules,\r\n      orderForm: {\r\n        woodType: '',\r\n        beastStyle: '',\r\n        length: 15,\r\n        width: 5,\r\n        height: 3,\r\n        isGilded: false,\r\n        remark: ''\r\n      },\r\n      rules: {\r\n        woodType: [\r\n          { required: true, message: '请选择木料种类', trigger: 'change' }\r\n        ],\r\n        beastStyle: [\r\n          { required: true, message: '请选择瑞兽款式', trigger: 'change' }\r\n        ],\r\n        length: [\r\n          { required: true, message: '请输入长度', trigger: 'blur' },\r\n          { type: 'number', min: sizeRules.length.min, max: sizeRules.length.max, message: `长度需在${sizeRules.length.min}-${sizeRules.length.max}厘米之间`, trigger: 'blur' }\r\n        ],\r\n        width: [\r\n          { required: true, message: '请输入宽度', trigger: 'blur' },\r\n          { type: 'number', min: sizeRules.width.min, max: sizeRules.width.max, message: `宽度需在${sizeRules.width.min}-${sizeRules.width.max}厘米之间`, trigger: 'blur' }\r\n        ],\r\n        height: [\r\n          { required: true, message: '请输入高度', trigger: 'blur' },\r\n          { type: 'number', min: sizeRules.height.min, max: sizeRules.height.max, message: `高度需在${sizeRules.height.min}-${sizeRules.height.max}厘米之间`, trigger: 'blur' }\r\n        ]\r\n      }\r\n    }\r\n  },\r\n  computed: {\r\n    totalPrice() {\r\n      let basePrice = orderStore.getWoodPrice(this.orderForm.woodType)\r\n      let gildedPrice = this.orderForm.isGilded ? 200 : 0\r\n      return basePrice + gildedPrice\r\n    }\r\n  },\r\n  methods: {\r\n    submitOrder() {\r\n      this.$refs.orderForm.validate((valid) => {\r\n        if (valid) {\r\n          const newOrder = orderStore.addOrder({ ...this.orderForm })\r\n          this.$message({\r\n            type: 'success',\r\n            message: `订单提交成功！订单号：${newOrder.id}`\r\n          })\r\n          this.resetForm()\r\n        } else {\r\n          this.$message.error('请完善订单信息后再提交')\r\n          return false\r\n        }\r\n      })\r\n    },\r\n    resetForm() {\r\n      this.$refs.orderForm.resetFields()\r\n      this.orderForm.isGilded = false\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.order-form-container {\r\n  max-width: 800px;\r\n  margin: 0 auto;\r\n}\r\n\r\n.order-card {\r\n  border-radius: 12px;\r\n}\r\n\r\n.card-header {\r\n  font-size: 20px;\r\n  font-weight: 600;\r\n  color: #8B4513;\r\n}\r\n\r\n.gilded-tip {\r\n  margin-left: 15px;\r\n  color: #E6A23C;\r\n  font-size: 14px;\r\n}\r\n\r\n.price-summary {\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: flex-start;\r\n  padding: 10px 0;\r\n}\r\n\r\n.price-label {\r\n  margin: 0;\r\n  font-size: 16px;\r\n  color: #606266;\r\n}\r\n\r\n.price-value {\r\n  margin: 0 0 0 10px;\r\n  font-size: 28px;\r\n  font-weight: 600;\r\n  color: #F56C6C;\r\n}\r\n\r\n.el-divider {\r\n  margin: 20px 0;\r\n}\r\n\r\n.el-divider__text {\r\n  color: #8B4513;\r\n  font-weight: 500;\r\n}\r\n</style>\r\n"]}]}