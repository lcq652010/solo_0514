{"ast":null,"code":"export default {\n  name: 'AppointmentList',\n  data() {\n    return {\n      loading: false,\n      searchForm: {\n        appointmentNo: '',\n        petName: '',\n        ownerName: '',\n        phone: '',\n        dateRange: [],\n        status: ''\n      },\n      tableData: [{\n        appointmentNo: 'AP20240115001',\n        petName: '豆豆',\n        petType: '狗',\n        breed: '金毛',\n        petGender: '公',\n        age: 3,\n        weight: 25,\n        ownerName: '张三',\n        phone: '13800138000',\n        appointmentDate: '2024-01-15',\n        timeSlot: '08:00-09:00',\n        department: '内科',\n        doctor: '张医生',\n        symptoms: '食欲不振，精神萎靡，持续两天',\n        status: '待就诊'\n      }, {\n        appointmentNo: 'AP20240115002',\n        petName: '咪咪',\n        petType: '猫',\n        breed: '英短',\n        petGender: '母',\n        age: 2,\n        weight: 4,\n        ownerName: '李四',\n        phone: '13900139000',\n        appointmentDate: '2024-01-15',\n        timeSlot: '09:00-10:00',\n        department: '皮肤科',\n        doctor: '王医生',\n        symptoms: '皮肤瘙痒，频繁抓挠，有脱毛现象',\n        status: '已就诊'\n      }, {\n        appointmentNo: 'AP20240116001',\n        petName: '旺财',\n        petType: '狗',\n        breed: '泰迪',\n        petGender: '公',\n        age: 5,\n        weight: 8,\n        ownerName: '王五',\n        phone: '13700137000',\n        appointmentDate: '2024-01-16',\n        timeSlot: '14:00-15:00',\n        department: '外科',\n        doctor: '李医生',\n        symptoms: '后腿跛行，不愿活动',\n        status: '已取消'\n      }, {\n        appointmentNo: 'AP20240114001',\n        petName: '花花',\n        petType: '猫',\n        breed: '布偶',\n        petGender: '母',\n        age: 1,\n        weight: 3,\n        ownerName: '赵六',\n        phone: '13600136000',\n        appointmentDate: '2024-01-14',\n        timeSlot: '10:00-11:00',\n        department: '疫苗接种',\n        doctor: '刘医生',\n        symptoms: '常规疫苗接种',\n        status: '已过期'\n      }],\n      pagination: {\n        currentPage: 1,\n        pageSize: 10,\n        total: 4\n      },\n      dialogVisible: false,\n      currentRecord: null\n    };\n  },\n  methods: {\n    getStatusType(status) {\n      const typeMap = {\n        '待就诊': '',\n        '已就诊': 'success',\n        '已取消': 'info',\n        '已过期': 'danger'\n      };\n      return typeMap[status] || '';\n    },\n    handleSearch() {\n      this.loading = true;\n      setTimeout(() => {\n        this.loading = false;\n        this.$message.success('查询完成');\n      }, 500);\n    },\n    handleReset() {\n      this.searchForm = {\n        appointmentNo: '',\n        petName: '',\n        ownerName: '',\n        phone: '',\n        dateRange: [],\n        status: ''\n      };\n    },\n    handleSizeChange(val) {\n      this.pagination.pageSize = val;\n    },\n    handleCurrentChange(val) {\n      this.pagination.currentPage = val;\n    },\n    handleView(row) {\n      this.currentRecord = row;\n      this.dialogVisible = true;\n    },\n    handleEdit(row) {\n      this.$message.info('跳转到编辑页面');\n    },\n    handleCancel(row) {\n      this.$confirm('确定要取消该预约吗？', '提示', {\n        confirmButtonText: '确定',\n        cancelButtonText: '取消',\n        type: 'warning'\n      }).then(() => {\n        row.status = '已取消';\n        this.$message.success('取消成功');\n      }).catch(() => {});\n    }\n  }\n};","map":{"version":3,"names":["name","data","loading","searchForm","appointmentNo","petName","ownerName","phone","dateRange","status","tableData","petType","breed","petGender","age","weight","appointmentDate","timeSlot","department","doctor","symptoms","pagination","currentPage","pageSize","total","dialogVisible","currentRecord","methods","getStatusType","typeMap","handleSearch","setTimeout","$message","success","handleReset","handleSizeChange","val","handleCurrentChange","handleView","row","handleEdit","info","handleCancel","$confirm","confirmButtonText","cancelButtonText","type","then","catch"],"sources":["src/views/AppointmentList.vue"],"sourcesContent":["<template>\r\n  <div class=\"page-container\">\r\n    <div class=\"page-title\">预约记录列表</div>\r\n    \r\n    <el-card class=\"box-card\">\r\n      <el-form :inline=\"true\" :model=\"searchForm\" class=\"demo-form-inline\">\r\n        <el-form-item label=\"预约编号\">\r\n          <el-input v-model=\"searchForm.appointmentNo\" placeholder=\"请输入预约编号\"></el-input>\r\n        </el-form-item>\r\n        <el-form-item label=\"宠物名称\">\r\n          <el-input v-model=\"searchForm.petName\" placeholder=\"请输入宠物名称\"></el-input>\r\n        </el-form-item>\r\n        <el-form-item label=\"主人姓名\">\r\n          <el-input v-model=\"searchForm.ownerName\" placeholder=\"请输入主人姓名\"></el-input>\r\n        </el-form-item>\r\n        <el-form-item label=\"联系电话\">\r\n          <el-input v-model=\"searchForm.phone\" placeholder=\"请输入联系电话\"></el-input>\r\n        </el-form-item>\r\n        <el-form-item label=\"预约日期\">\r\n          <el-date-picker\r\n            v-model=\"searchForm.dateRange\"\r\n            type=\"daterange\"\r\n            range-separator=\"至\"\r\n            start-placeholder=\"开始日期\"\r\n            end-placeholder=\"结束日期\">\r\n          </el-date-picker>\r\n        </el-form-item>\r\n        <el-form-item label=\"预约状态\">\r\n          <el-select v-model=\"searchForm.status\" placeholder=\"请选择状态\">\r\n            <el-option label=\"全部\" value=\"\"></el-option>\r\n            <el-option label=\"待就诊\" value=\"待就诊\"></el-option>\r\n            <el-option label=\"已就诊\" value=\"已就诊\"></el-option>\r\n            <el-option label=\"已取消\" value=\"已取消\"></el-option>\r\n            <el-option label=\"已过期\" value=\"已过期\"></el-option>\r\n          </el-select>\r\n        </el-form-item>\r\n        <el-form-item>\r\n          <el-button type=\"primary\" @click=\"handleSearch\">查询</el-button>\r\n          <el-button @click=\"handleReset\">重置</el-button>\r\n        </el-form-item>\r\n      </el-form>\r\n      \r\n      <el-table :data=\"tableData\" border style=\"width: 100%\" v-loading=\"loading\">\r\n        <el-table-column type=\"selection\" width=\"55\"></el-table-column>\r\n        <el-table-column prop=\"appointmentNo\" label=\"预约编号\" width=\"150\"></el-table-column>\r\n        <el-table-column prop=\"petName\" label=\"宠物名称\" width=\"100\"></el-table-column>\r\n        <el-table-column prop=\"petType\" label=\"宠物类型\" width=\"80\"></el-table-column>\r\n        <el-table-column prop=\"breed\" label=\"品种\" width=\"100\"></el-table-column>\r\n        <el-table-column prop=\"ownerName\" label=\"主人姓名\" width=\"100\"></el-table-column>\r\n        <el-table-column prop=\"phone\" label=\"联系电话\" width=\"120\"></el-table-column>\r\n        <el-table-column prop=\"appointmentDate\" label=\"预约日期\" width=\"150\"></el-table-column>\r\n        <el-table-column prop=\"timeSlot\" label=\"时段\" width=\"120\"></el-table-column>\r\n        <el-table-column prop=\"department\" label=\"科室\" width=\"100\"></el-table-column>\r\n        <el-table-column prop=\"doctor\" label=\"医师\" width=\"100\"></el-table-column>\r\n        <el-table-column prop=\"status\" label=\"状态\" width=\"100\">\r\n          <template slot-scope=\"scope\">\r\n            <el-tag :type=\"getStatusType(scope.row.status)\">\r\n              {{ scope.row.status }}\r\n            </el-tag>\r\n          </template>\r\n        </el-table-column>\r\n        <el-table-column label=\"操作\" width=\"200\">\r\n          <template slot-scope=\"scope\">\r\n            <el-button size=\"mini\" type=\"primary\" @click=\"handleView(scope.row)\">查看</el-button>\r\n            <el-button size=\"mini\" type=\"success\" @click=\"handleEdit(scope.row)\" :disabled=\"scope.row.status !== '待就诊'\">编辑</el-button>\r\n            <el-button size=\"mini\" type=\"danger\" @click=\"handleCancel(scope.row)\" :disabled=\"scope.row.status !== '待就诊'\">取消</el-button>\r\n          </template>\r\n        </el-table-column>\r\n      </el-table>\r\n      \r\n      <div class=\"pagination-container\