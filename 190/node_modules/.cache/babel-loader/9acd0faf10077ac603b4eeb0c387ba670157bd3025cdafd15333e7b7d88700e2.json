{"ast":null,"code":"export default {\n  name: 'Appointment',\n  data() {\n    const validatePhone = (rule, value, callback) => {\n      if (!value) {\n        callback(new Error('请输入联系电话'));\n      } else if (!/^1[3-9]\\d{9}$/.test(value)) {\n        callback(new Error('请输入正确的手机号码'));\n      } else {\n        callback();\n      }\n    };\n    return {\n      appointmentForm: {\n        petName: '',\n        petType: '',\n        breed: '',\n        petGender: '公',\n        age: 1,\n        weight: 5,\n        ownerName: '',\n        phone: '',\n        backupPhone: '',\n        appointmentDate: '',\n        timeSlot: '',\n        department: '',\n        doctor: '',\n        symptoms: ''\n      },\n      rules: {\n        petName: [{\n          required: true,\n          message: '请输入宠物名称',\n          trigger: 'blur'\n        }],\n        petType: [{\n          required: true,\n          message: '请选择宠物类型',\n          trigger: 'change'\n        }],\n        breed: [{\n          required: true,\n          message: '请输入宠物品种',\n          trigger: 'blur'\n        }],\n        ownerName: [{\n          required: true,\n          message: '请输入主人姓名',\n          trigger: 'blur'\n        }],\n        phone: [{\n          required: true,\n          validator: validatePhone,\n          trigger: 'blur'\n        }],\n        appointmentDate: [{\n          required: true,\n          message: '请选择预约日期',\n          trigger: 'change'\n        }],\n        timeSlot: [{\n          required: true,\n          message: '请选择预约时段',\n          trigger: 'change'\n        }],\n        department: [{\n          required: true,\n          message: '请选择就诊科室',\n          trigger: 'change'\n        }],\n        doctor: [{\n          required: true,\n          message: '请选择医师',\n          trigger: 'change'\n        }],\n        symptoms: [{\n          required: true,\n          message: '请描述症状',\n          trigger: 'blur'\n        }]\n      }\n    };\n  },\n  methods: {\n    handleSubmit() {\n      this.$refs.appointmentForm.validate(valid => {\n        if (valid) {\n          this.$alert('预约成功！预约号：AP' + Date.now(), '提示', {\n            confirmButtonText: '确定',\n            callback: action => {\n              this.handleReset();\n            }\n          });\n        }\n      });\n    },\n    handleReset() {\n      this.$refs.appointmentForm.resetFields();\n    }\n  }\n};","map":{"version":3,"names":["name","data","validatePhone","rule","value","callback","Error","test","appointmentForm","petName","petType","breed","petGender","age","weight","ownerName","phone","backupPhone","appointmentDate","timeSlot","department","doctor","symptoms","rules","required","message","trigger","validator","methods","handleSubmit","$refs","validate","valid","$alert","Date","now","confirmButtonText","action","handleReset","resetFields"],"sources":["src/views/Appointment.vue"],"sourcesContent":["<template>\r\n  <div class=\"page-container\">\r\n    <div class=\"page-title\">宠物就诊预约</div>\r\n    \r\n    <el-card class=\"box-card\">\r\n      <el-form :model=\"appointmentForm\" :rules=\"rules\" ref=\"appointmentForm\" label-width=\"120px\">\r\n        <el-divider content-position=\"left\">宠物信息</el-divider>\r\n        <el-row :gutter=\"20\">\r\n          <el-col :span=\"8\">\r\n            <el-form-item label=\"宠物名称\" prop=\"petName\">\r\n              <el-input v-model=\"appointmentForm.petName\"></el-input>\r\n            </el-form-item>\r\n          </el-col>\r\n          <el-col :span=\"8\">\r\n            <el-form-item label=\"宠物类型\" prop=\"petType\">\r\n              <el-select v-model=\"appointmentForm.petType\" style=\"width: 100%\">\r\n                <el-option label=\"狗\" value=\"狗\"></el-option>\r\n                <el-option label=\"猫\" value=\"猫\"></el-option>\r\n                <el-option label=\"鸟\" value=\"鸟\"></el-option>\r\n                <el-option label=\"其他\" value=\"其他\"></el-option>\r\n              </el-select>\r\n            </el-form-item>\r\n          </el-col>\r\n          <el-col :span=\"8\">\r\n            <el-form-item label=\"品种\" prop=\"breed\">\r\n              <el-input v-model=\"appointmentForm.breed\"></el-input>\r\n            </el-form-item>\r\n          </el-col>\r\n        </el-row>\r\n        <el-row :gutter=\"20\">\r\n          <el-col :span=\"8\">\r\n            <el-form-item label=\"性别\" prop=\"petGender\">\r\n              <el-radio-group v-model=\"appointmentForm.petGender\">\r\n                <el-radio label=\"公\"></el-radio>\r\n                <el-radio label=\"母\"></el-radio>\r\n              </el-radio-group>\r\n            </el-form-item>\r\n          </el-col>\r\n          <el-col :span=\"8\">\r\n            <el-form-item label=\"年龄(岁)\" prop=\"age\">\r\n              <el-input-number v-model=\"appointmentForm.age\" :min=\"0\" :max=\"30\"></el-input-number>\r\n            </el-form-item>\r\n          </el-col>\r\n          <el-col :span=\"8\">\r\n            <el-form-item label=\"体重(kg)\" prop=\"weight\">\r\n              <el-input-number v-model=\"appointmentForm.weight\" :min=\"0\" :max=\"100\" :step=\"0.1\"></el-input-number>\r\n            </el-form-item>\r\n          </el-col>\r\n        </el-row>\r\n        \r\n        <el-divider content-position=\"left\">主人信息</el-divider>\r\n        <el-row :gutter=\"20\">\r\n          <el-col :span=\"8\">\r\n            <el-form-item label=\"主人姓名\" prop=\"ownerName\">\r\n              <el-input v-model=\"appointmentForm.ownerName\"></el-input>\r\n            </el-form-item>\r\n          </el-col>\r\n          <el-col :span=\"8\">\r\n            <el-form-item label=\"联系电话\" prop=\"phone\">\r\n              <el-input v-model=\"appointmentForm.phone\"></el-input>\r\n            </el-form-item>\r\n          </el-col>\r\n          <el-col :span=\"8\">\r\n            <el-form-item label=\"备用电话\" prop=\"backupPhone\">\r\n              <el-input v-model=\"appointmentForm.backupPhone\"></el-input>\r\n            </el-form-item>\r\n          </el-col>\r\n        </el-row>\r\n        \r\n        <el-divider content-position=\"left\">预约信息</el-divider>\r\n        <el-row :gutter=\"20\">\r\n          <el-col :span=\"8\">\r\n            <el-form-item label=\"预约日期\" prop=\"appointmentDate\">\r\n              <el-date-picker\r\n                v-model=\"appointmentForm.appointmentDate\"\r\n                type=\"date\"\r\n                placeholder=\"选择日期\"\r\n                style=\"width: 100%\">\r\n              </el-date-picker>\r\n            </el-form-item>\r\n          </el-col>\r\n          <el-col :span=\"8\">\r\n            <el-form-item label=\"预约时段\" prop=\"timeSlot\">\r\n              <el-select v-model=\"appointmentForm.timeSlot\" style=\"width: 100%\">\r\n                <el-option label=\"08:00-09:00\" value=\"08:00-09:00\"></el-option>\r\n                <el-option label=\"09:00-10:00\" value=\"09:00-10:00\"></el-option>\r\n                <el-option label=\"10:00-11:00\" value=\"10:00-11:00\"></el-option>\r\n                <el-option label=\"11:00-12:00\" value=\"11:00-12:00\"></el-option>\r\n                <el-option label=\"14:00-15:00\" value=\"14:00-15:00\"></el-option>\r\n                <el-option label=\"15:00-16:00\" value=\"15:00-16:00\"></el-option>\r\n                <el-option label=\"16:00-17:00\" value=\"16:00-17:00\"></el-option>\r\n                <el-option label=\"17:00-18:00\" value=\"17:00-18:00\"></el-option>\r\n              </el-select>\r\n            </el-form-item>\r\n          </el-col>\r\n          <el-col :span=\"8\">\r\n            <el-form-item label=\"就诊科室\" prop=\"department\">\r\n              <el-select v-model=\"appointmentForm.department\" style=\"width: 100%\">\r\n                <el-option label=\"内科\" value=\"内科\"></el-option>\r\n                <el-option label=\"外科\" value=\"外科\"></el-option>\r\n                <el-option label=\"皮肤科\" value=\"皮肤科\"></el-option>\r\n                <el-option label=\"眼科\" value=\"眼科\"></el-option>\r\n                <el-option label=\"牙科\" value=\"牙科\"></el-option>\r\n                <el-option label=\"疫苗接种\" value=\"疫苗接种\"></el-option>\r\n              </el-select>\r\n            </el-form-item>\r\n          </el-col>\r\n        </el-row>\r\n        <el-row :gutter=\"20\">\r\n          <el-col :span=\"8\">\r\n            <el-form-item label=\"选择医师\" prop=\"doctor\">\r\n              <el-select v-model=\"appointmentForm.doctor\" style=\"width: 100%\">\r\n                <el-option label=\"张医生\" value=\"张医生\"></el-option>\r\n                <el-option label=\"李医生\" value=\"李医生\"></el-option>\r\n                <el-option label=\"王医生\" value=\"王医生\"></el-option>\r\n                <el-option label=\"赵医生\" value=\"赵医生\"></el-option>\r\n                <el-option label=\"刘医生\" value=\"刘医生\"></el-option>\r\n              </el-select>\r\n            </el-form-item>\r\n          </el-col>\r\n          <el-col :span=\"16\">\r\n            <el-form-item label=\"症状描述\" prop=\"symptoms\">\r\n              <el-input\r\n                type=\"textarea\"\r\n                :rows=\"3\"\r\n                v-model=\"appointmentForm.symptoms\"\r\n                placeholder=\"请详细描述宠物的症状情况\">\r\n              </el-input>\r\n            </el-form-item>\r\n          </el-col>\r\n        </el-row>\r\n        \r\n        <el-row>\r\n          <el-col :span=\"24\" style=\"text-align: center;\">\r\n            <el-form-item>\r\n              <el-button type=\"primary\" size=\"large\" @click=\"handleSubmit\">提交预约</el-button>\r\n              <el-button size=\"large\" @click=\"handleReset\">重置表单</el-button>\r\n            </el-form-item>\r\n          </el-col>\r\n        </el-row>\r\n      </el-form>\r\n    </el-card>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: 'Appointment',\r\n  data() {\r\n    const validatePhone = (rule, value, callback) => {\r\n      if (!value) {\r\n        callback(new Error('请输入联系电话'))\r\n      } else if (!/^1[3-9]\\d{9}$/.test(value)) {\r\n        callback(new Error('请输入正确的手机号码'))\r\n      } else {\r\n        callback()\r\n      }\r\n    }\r\n    \r\n    return {\r\n      appointmentForm: {\r\n        petName: '',\r\n        petType: '',\r\n        breed: '',\r\n        petGender: '公',\r\n        age: 1,\r\n        weight: 5,\r\n        ownerName: '',\r\n        phone: '',\r\n        backupPhone: '',\r\n        appointmentDate: '',\r\n        timeSlot: '',\r\n        department: '',\r\n        doctor: '',\r\n        symptoms: ''\r\n      },\r\n      rules: {\r\n        petName: [\r\n          { required: true, message: '请输入宠物名称', trigger: 'blur' }\r\n        ],\r\n        petType: [\r\n          { required: true, message: '请选择宠物类型', trigger: 'change' }\r\n        ],\r\n        breed: [\r\n          { required: true, message: '请输入宠物品种', trigger: 'blur' }\r\n        ],\r\n        ownerName: [\r\n          { required: true, message: '请输入主人姓名', trigger: 'blur' }\r\n        ],\r\n        phone: [\r\n          { required: true, validator: validatePhone, trigger: 'blur' }\r\n        ],\r\n        appointmentDate: [\r\n          { required: true, message: '请选择预约日期', trigger: 'change' }\r\n        ],\r\n        timeSlot: [\r\n          { required: true, message: '请选择预约时段', trigger: 'change' }\r\n        ],\r\n        department: [\r\n          { required: true, message: '请选择就诊科室', trigger: 'change' }\r\n        ],\r\n        doctor: [\r\n          { required: true, message: '请选择医师', trigger: 'change' }\r\n        ],\r\n        symptoms: [\r\n          { required: true, message: '请描述症状', trigger: 'blur' }\r\n        ]\r\n      }\r\n    }\r\n  },\r\n  methods: {\r\n    handleSubmit() {\r\n      this.$refs.appointmentForm.validate((valid) => {\r\n        if (valid) {\r\n          this.$alert('预约成功！预约号：AP' + Date.now(), '提示', {\r\n            confirmButtonText: '确定',\r\n            callback: action => {\r\n              this.handleReset()\r\n            }\r\n          })\r\n        }\r\n      })\r\n    },\r\n    handleReset() {\r\n      this.$refs.appointmentForm.resetFields()\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n</style>\r\n"],"mappings":"AAkJA;EACAA,IAAA;EACAC,KAAA;IACA,MAAAC,aAAA,GAAAA,CAAAC,IAAA,EAAAC,KAAA,EAAAC,QAAA;MACA,KAAAD,KAAA;QACAC,QAAA,KAAAC,KAAA;MACA,4BAAAC,IAAA,CAAAH,KAAA;QACAC,QAAA,KAAAC,KAAA;MACA;QACAD,QAAA;MACA;IACA;IAEA;MACAG,eAAA;QACAC,OAAA;QACAC,OAAA;QACAC,KAAA;QACAC,SAAA;QACAC,GAAA;QACAC,MAAA;QACAC,SAAA;QACAC,KAAA;QACAC,WAAA;QACAC,eAAA;QACAC,QAAA;QACAC,UAAA;QACAC,MAAA;QACAC,QAAA;MACA;MACAC,KAAA;QACAd,OAAA,GACA;UAAAe,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA,EACA;QACAhB,OAAA,GACA;UAAAc,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA,EACA;QACAf,KAAA,GACA;UAAAa,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA,EACA;QACAX,SAAA,GACA;UAAAS,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA,EACA;QACAV,KAAA,GACA;UAAAQ,QAAA;UAAAG,SAAA,EAAAzB,aAAA;UAAAwB,OAAA;QAAA,EACA;QACAR,eAAA,GACA;UAAAM,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA,EACA;QACAP,QAAA,GACA;UAAAK,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA,EACA;QACAN,UAAA,GACA;UAAAI,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA,EACA;QACAL,MAAA,GACA;UAAAG,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA,EACA;QACAJ,QAAA,GACA;UAAAE,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;MAEA;IACA;EACA;EACAE,OAAA;IACAC,aAAA;MACA,KAAAC,KAAA,CAAAtB,eAAA,CAAAuB,QAAA,CAAAC,KAAA;QACA,IAAAA,KAAA;UACA,KAAAC,MAAA,iBAAAC,IAAA,CAAAC,GAAA;YACAC,iBAAA;YACA/B,QAAA,EAAAgC,MAAA;cACA,KAAAC,WAAA;YACA;UACA;QACA;MACA;IACA;IACAA,YAAA;MACA,KAAAR,KAAA,CAAAtB,eAAA,CAAA+B,WAAA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}