{"remainingRequest":"C:\\Users\\86138\\Desktop\\solo_0516\\102\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!C:\\Users\\86138\\Desktop\\solo_0516\\102\\src\\components\\FaultReportModal.vue?vue&type=style&index=0&id=c724eb86&prod&scoped=true&lang=css","dependencies":[{"path":"C:\\Users\\86138\\Desktop\\solo_0516\\102\\src\\components\\FaultReportModal.vue","mtime":1778918744142},{"path":"C:\\Users\\86138\\Desktop\\solo_0516\\102\\node_modules\\css-loader\\dist\\cjs.js","mtime":1778918866578},{"path":"C:\\Users\\86138\\Desktop\\solo_0516\\102\\node_modules\\vue-loader\\lib\\loaders\\stylePostLoader.js","mtime":1778918882398},{"path":"C:\\Users\\86138\\Desktop\\solo_0516\\102\\node_modules\\postcss-loader\\src\\index.js","mtime":1778918872147},{"path":"C:\\Users\\86138\\Desktop\\solo_0516\\102\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1778918863585},{"path":"C:\\Users\\86138\\Desktop\\solo_0516\\102\\node_modules\\vue-loader\\lib\\index.js","mtime":1778918877533}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:DQouZGlhbG9nLWZvb3RlciB7DQogIHRleHQtYWxpZ246IHJpZ2h0Ow0KfQ0K"},{"version":3,"sources":["FaultReportModal.vue"],"names":[],"mappings":";AAqJA;AACA;AACA","file":"FaultReportModal.vue","sourceRoot":"src/components","sourcesContent":["<template>\r\n  <el-dialog \r\n    title=\"故障上报\" \r\n    :visible.sync=\"visible\" \r\n    width=\"600px\"\r\n    :close-on-click-modal=\"false\"\r\n    @close=\"handleClose\"\r\n  >\r\n    <el-form :model=\"form\" :rules=\"rules\" ref=\"form\" label-width=\"100px\">\r\n      <el-form-item label=\"选择设备\" prop=\"deviceId\">\r\n        <el-select \r\n          v-model=\"form.deviceId\" \r\n          placeholder=\"请选择故障设备\" \r\n          style=\"width: 100%;\"\r\n          filterable\r\n        >\r\n          <el-option\r\n            v-for=\"device in deviceList\"\r\n            :key=\"device.id\"\r\n            :label=\"`${device.deviceCode} - ${device.branchName}`\"\r\n            :value=\"device.id\"\r\n          >\r\n            <span style=\"float: left;\">{{ device.deviceCode }}</span>\r\n            <span style=\"float: right; color: #8492a6; font-size: 13px;\">{{ device.branchName }}</span>\r\n          </el-option>\r\n        </el-select>\r\n      </el-form-item>\r\n      \r\n      <el-form-item label=\"设备编号\" v-if=\"selectedDevice\">\r\n        <el-input :value=\"selectedDevice.deviceCode\" disabled />\r\n      </el-form-item>\r\n      \r\n      <el-form-item label=\"所属网点\" v-if=\"selectedDevice\">\r\n        <el-input :value=\"selectedDevice.branchName\" disabled />\r\n      </el-form-item>\r\n      \r\n      <el-form-item label=\"放置区域\" v-if=\"selectedDevice\">\r\n        <el-input :value=\"selectedDevice.area\" disabled />\r\n      </el-form-item>\r\n      \r\n      <el-form-item label=\"故障说明\" prop=\"description\">\r\n        <el-input\r\n          type=\"textarea\"\r\n          v-model=\"form.description\"\r\n          placeholder=\"请详细描述故障情况，如：设备无法启动、触摸屏失灵、打印异常等\"\r\n          :rows=\"4\"\r\n          maxlength=\"500\"\r\n          show-word-limit\r\n        />\r\n      </el-form-item>\r\n      \r\n      <el-form-item label=\"联系人\">\r\n        <el-input v-model=\"form.contact\" placeholder=\"请输入联系人姓名\" />\r\n      </el-form-item>\r\n      \r\n      <el-form-item label=\"联系电话\">\r\n        <el-input v-model=\"form.phone\" placeholder=\"请输入联系电话\" />\r\n      </el-form-item>\r\n    </el-form>\r\n    \r\n    <div slot=\"footer\" class=\"dialog-footer\">\r\n      <el-button @click=\"handleClose\">取 消</el-button>\r\n      <el-button type=\"primary\" @click=\"handleSubmit\" :loading=\"loading\">提交工单</el-button>\r\n    </div>\r\n  </el-dialog>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: 'FaultReportModal',\r\n  props: {\r\n    deviceList: {\r\n      type: Array,\r\n      default: () => []\r\n    }\r\n  },\r\n  data() {\r\n    return {\r\n      visible: false,\r\n      loading: false,\r\n      form: {\r\n        deviceId: null,\r\n        description: '',\r\n        contact: '',\r\n        phone: ''\r\n      },\r\n      rules: {\r\n        deviceId: [\r\n          { required: true, message: '请选择故障设备', trigger: 'change' }\r\n        ],\r\n        description: [\r\n          { required: true, message: '请填写故障说明', trigger: 'blur' },\r\n          { min: 5, message: '故障说明至少5个字符', trigger: 'blur' }\r\n        ]\r\n      }\r\n    }\r\n  },\r\n  computed: {\r\n    selectedDevice() {\r\n      if (!this.form.deviceId) return null\r\n      return this.deviceList.find(d => d.id === this.form.deviceId)\r\n    }\r\n  },\r\n  methods: {\r\n    open(device = null) {\r\n      this.resetForm()\r\n      if (device) {\r\n        this.form.deviceId = device.id\r\n      }\r\n      this.visible = true\r\n    },\r\n    handleClose() {\r\n      this.visible = false\r\n      this.resetForm()\r\n    },\r\n    resetForm() {\r\n      this.form = {\r\n        deviceId: null,\r\n        description: '',\r\n        contact: '',\r\n        phone: ''\r\n      }\r\n      if (this.$refs.form) {\r\n        this.$refs.form.resetFields()\r\n      }\r\n    },\r\n    handleSubmit() {\r\n      this.$refs.form.validate((valid) => {\r\n        if (valid) {\r\n          this.loading = true\r\n          \r\n          setTimeout(() => {\r\n            this.loading = false\r\n            this.$emit('submit', {\r\n              deviceId: this.form.deviceId,\r\n              description: this.form.description,\r\n              contact: this.form.contact,\r\n              phone: this.form.phone\r\n            })\r\n            this.handleClose()\r\n          }, 800)\r\n        }\r\n      })\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.dialog-footer {\r\n  text-align: right;\r\n}\r\n</style>\r\n"]}]}